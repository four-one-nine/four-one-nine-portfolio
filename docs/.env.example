# four.one.nine Portfolio - Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# FRONTEND (Next.js) - apps/web/.env.local
# ============================================
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_USE_MOCK=false
PAYLOAD_SECRET=your-secret-key-here
PORT=3001

# MongoDB (required)
MONGODB_URI=mongodb+srv://owner_db_user:swINaxASXsWhlhhl@four-one-nine-personal.cqh7k05.mongodb.net/?appName=four-one-nine-personal

# Email (Nodemailer) - optional
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
CONTACT_EMAIL=your-email@example.com

# ============================================
# CMS (Payload) - apps/cms/.env
# ============================================
# PAYLOAD_SECRET and MONGODB_URI are shared with frontend
# Additional CMS-specific variables:

# CMS-specific settings (optional)
# PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000