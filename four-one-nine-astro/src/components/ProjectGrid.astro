---
import ProjectCard from './ProjectCard.astro'

interface Props {
  projects: Array<{
    slug: string
    data: {
      title: string
      description: string
      featuredImage: string
      category: string
      externalUrl?: string
      tags?: string[]
    }
  }>
}

const { projects } = Astro.props;
---

<div class="project-grid grid grid-cols-1 lg:grid-cols-3 items-stretch">
  {projects.map((project, index) => {
    const isWide = index % 2 === 0;
    const rowIndex = Math.floor(index / 2) + 1;
    const narrowOnLeft = Math.floor(index / 2) % 2 === 0;

    let gridClass = 'grid-item';
    const style: { [key: string]: string } = { animationDelay: `${index * 0.1}s` };

    style['--grid-row'] = String(rowIndex);

    if (isWide) {
      style['--grid-column-wide'] = narrowOnLeft ? '2 / 4' : '1 / 3';
    } else {
      style['--grid-column'] = narrowOnLeft ? '1' : '3';
    }

    return (
      <div class={gridClass} style={style} data-category={project.data.category} data-wide={isWide || undefined}>
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          featuredImage={project.data.featuredImage}
          category={project.data.category}
          externalUrl={project.data.externalUrl}
          slug={project.slug}
          tags={project.data.tags}
        />
      </div>
    );
  })}
</div>