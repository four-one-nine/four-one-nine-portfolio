---
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutData from '../data/about.json';
---

<BaseLayout title={`About | ${aboutData.name}`} description={aboutData.blurb}>
  <div class="pt-4 lg:pt-8 px-4 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="mb-8" style="border-bottom: 1px solid rgba(55, 55, 55, 0.5); padding-bottom: 2rem;">
        <h1 class="font-mono text-4xl font-bold mb-4">About</h1>
      </div>
      
      <div class="flex flex-col md:flex-row gap-8">
        <div class="md:w-1/3">
          <img src={aboutData.photo} alt={aboutData.name} class="w-full rounded-xl object-cover aspect-square" />
        </div>
        <div class="md:w-2/3">
          <h2 class="font-mono text-3xl font-bold mb-4">{aboutData.name}</h2>
          <p class="text-lg leading-relaxed mb-6" style="color: #373737;">{aboutData.blurb}</p>
          <a href="/contact" class="get-in-touch inline-block" style="color: #373737;">
            Get in touch →
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>