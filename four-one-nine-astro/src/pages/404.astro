---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | four.one.nine" description="Page not found">
  <div class="flex items-center justify-center min-h-[60vh] px-4">
    <div class="text-center">
      <h1 class="font-mono text-8xl font-bold mb-4" style="color: #373737;">404</h1>
      <p class="text-xl mb-8" style="color: #373737;">Page not found</p>
      <a href="/" class="get-in-touch inline-block" style="color: #373737;">
        ← Back to home
      </a>
    </div>
  </div>
</BaseLayout>